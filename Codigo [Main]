			nombre = e.nextLine().trim();
			if (nombre.isEmpty()) {
				System.out.println("❌ El nombre no puede estar vacío.");
				nombreValido = false;
				continue;
			} else if (nombre.endsWith(".")) {
				System.out.println("❌ El nombre no puede terminar en punto (eso es para los bots).");
				nombreValido = false;
				continue;
			}
		} while (!nombreValido);
		//Añadimos al usuario en el arraylist de equipos
		Planeta nuevoPlaneta = new Planeta(vidaPers, misilesIniciales);
		nuevoPlaneta.setNombre(nombre);
		equipos.add(nuevoPlaneta);
		
		//Añadimos los bots con nombres aleatorios
		for (int i = 1; i < numEquipos; i++) {
			nombre = "";
			int numRandom = numAleatorio(0, nomAleatorio.size() - 1);
			nombre = nomAleatorio.get(numRandom);
			nomAleatorio.remove(numRandom);
			
			nuevoPlaneta = new Planeta(vidaPers, misilesIniciales);
			nuevoPlaneta.setNombre(nombre);
			equipos.add(nuevoPlaneta);
		}
	}

	/**
	 * Produce un valor numérico entero acotado por un margen inferior y superior dinámicos,
	 * facilitando su versatilidad paramétrica tanto para manipulación de índices como gasto logístico.
	 * @param minimo Limite inferior inquebrantable que puede arrojar la ecuación.
	 * @param maximo Límite superior del espectro aleatorio habilitado.
	 * @return Entero encapsulado en la banda determinada, aplicando corrección distributiva por redondeo matemático.
	 */
	public static int numAleatorio(int minimo, int maximo) {
		return (int) (Math.random() * (maximo - minimo + 1)) + minimo;
	}
	
	/**
	 * Motor de decisiones simuladas. Gobierna la secuencia de un turno automatizado estructurando 
	 * de forma probabilística la elección del objetivo táctico y el racionamiento de recursos de fuego.
	 * @param equipos          Contexto global de entidades para el mapeo de blancos.
	 * @param vidaInicialRonda Registro temporal para discriminar a las unidades caídas en fases muy recientes.
	 * @param ronda            Marcador cronológico implicado en validaciones de defensa.
	 * @param atacante         Agente robótico actualmente sujeto a proceso de resolución.
	 * @return Un registro crudo encapsulado de todos los comandos de combate generados que será devuelto al controlador principal.
	 */
	public static String atacarBots(ArrayList<Planeta> equipos, int[] vidaInicialRonda, int ronda, Planeta atacante) {
		String logBot = "";
		
		while (atacante.getMisiles_ronda() > 0) {
			Planeta[] objetivos = new Planeta[equipos.size()];
			int opcionesDisponibles = mostrarObjetivos(atacante, equipos, objetivos, ronda, vidaInicialRonda);
			int opcion = -1;
			
			do {
				opcion = numAleatorio(0, opcionesDisponibles);
				if (opcion == 0 && ronda == 1) {
					opcion = -1; 
				}
			} while (opcion < 0 || opcion > opcionesDisponibles);

			if (opcion == 0) {

				int misilesDefensa = numAleatorio(1, atacante.getMisiles_ronda());
				logBot += atacante.curar(misilesDefensa);
			} else {
				int misilesLanzar = numAleatorio(1, atacante.getMisiles_ronda());
				Planeta objetivo = objetivos[opcion - 1];
				logBot += atacante.combate(misilesLanzar, objetivo);
			}
		}
		
		return logBot;
	}

