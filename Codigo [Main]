	public static void salir() {
		System.out.println("Fin del juego");
	}

	/**
	 * Captura y procesa la entrada del usuario de forma robusta, asegurando que la 
	 * conversión a número entero sea exitosa y previendo excepciones de formato.
	 * @return El número entero extraído y validado de la entrada del usuario.
	 */
	public static int pedirNumero() {
		int cantidad = -1;
		boolean esNumero = false;
		do {
			try {
				String input = e.nextLine().trim();
				if (input.isEmpty()) {
					System.out.print("Por favor, introduce un número: ");
					continue;
				}
				cantidad = Integer.parseInt(input);
				esNumero = true;
			} catch (NumberFormatException ex) {
				System.out.print("No es un número válido. Intenta de nuevo: ");
			}
		} while (!esNumero);
		return cantidad;
	}

	/**
	 * Gestiona la inserción de cantidades de munición para acciones ofensivas o defensivas,
	 * limitando la elección a la reserva actual del jugador y forzando un gasto mínimo lógico.
	 * @param maximoDisponible Cantidad máxima de misiles que el jugador posee sin gastar.
	 * @return La cantidad final de misiles aprobada para ejecutar la acción.
	 */
	public static int pedirMisilesValidos(int maximoDisponible) {
		int cantidad;
		do {
			cantidad = pedirNumero();
			if (cantidad < 1) {
				System.out.print("Debes usar al menos 1: ");
			} else if (cantidad > maximoDisponible) {
				System.out.print("Solo tienes " + maximoDisponible + " misiles: ");
			}
		} while (cantidad < 1 || cantidad > maximoDisponible);
		return cantidad;
	}

	/**
	 * Despliega en consola un resumen de la vitalidad y tipología de todos los equipos 
	 * que conforman la partida, aplicando máscaras estéticas para facilitar su lectura.
	 * @param equipos     Estructura de datos con todos los planetas de la sesión activa.
	 * @param tipoPartida Permite a la función discernir si debe anunciar ventajas de clase (Modo Normal).
	 */
	public static void imprimirEstadoEquipos(ArrayList<Planeta> equipos, int tipoPartida) {
		for (Planeta p : equipos) {
			if (p.getVidas() > 0) {
				// EN caso de haber elegido la partida nromal tambien mostramos los tipos de planetas seleccionados por cada equipo
				if (tipoPartida == 2) {
					String[] tipos = { "", "Normal", "Rojo", "Azul", "Verde", "Gigante", "Enano" };
					System.out.println(
							"[+] " + p.getNombre().replace('.', ' ') + " (" + tipos[p.getTipo()] + ") ---> " + p.getVidas() + " HP");
				} else {
					System.out.println("[+] " + p.getNombre().replace('.', ' ') + " ---> " + p.getVidas() + " HP");
				}
			} else {
				System.out.println("[-] " + p.getNombre().replace('.', ' ') + " ---> DESTRUIDO");
			}
		}
	}

	/**
	 * Construye el menú contextual de objetivos disponibles en el turno activo, filtrando bajas
	 * y almacenando internamente las referencias precisas para ejecutar ataques posteriores.
	 * @param atacante         Entidad que ostenta la titularidad del turno actual.
	 * @param equipos          Totalidad de los participantes registrados.
	 * @param objetivos        Matriz temporal destinada a relacionar las opciones numéricas con las entidades reales.
	 * @param ronda            Indicador cronológico que permite inhabilitar la defensa en etapas prematuras.
	 * @param vidaInicialRonda Registro de salud para discriminar blancos válidos caídos previamente en la ronda.
	 * @return Un entero con la cifra máxima de opciones de ataque catalogadas.
	 */
	public static int mostrarObjetivos(Planeta atacante, ArrayList<Planeta> equipos, Planeta[] objetivos, int ronda,
			int[] vidaInicialRonda) {
		int pos = 0;
		for (int i = 0; i < equipos.size(); i++) {
			Planeta p = equipos.get(i);
			if (p != atacante && vidaInicialRonda[i] > 0) {
				objetivos[pos] = p;
				if (!atacante.getNombre().endsWith(".")) {
					System.out.println((pos + 1) + ". Atacar a " + p.getNombre().replace('.', ' ') + " ("
							+ vidaInicialRonda[i] + " HP)");
				}
				pos++;
			}
		}
		
		if (!atacante.getNombre().endsWith(".")) {
			if (ronda == 1) {
				System.out.println("0. Defender (BLOQUEADO EN RONDA 1)");
			} else {
				System.out.println("0. Defender y recuperar HP");
			}
		}
		return pos;
	}

