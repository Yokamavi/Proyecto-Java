	/**
	 * Evalúa el número de supervivientes activos en el panorama general de la partida.
	 * @param equipos Estructura de datos completa de entidades a revisar.
	 * @return La suma cuantitativa de todos los elementos cuyo valor vital supera el umbral del cero.
	 */
	public static int contarVivos(ArrayList<Planeta> equipos) {
		int vivos = 0;
		for (Planeta p : equipos) {
			if (p.getVidas() > 0) {
				vivos++;
			}
		}
		return vivos;
	}

	/**
	 * Analiza el estado final de la partida para identificar al vencedor absoluto, procesa
	 * el resultado hacia la base de datos histórica persistente y devuelve la confirmación.
	 * @param equipos Lista con el estado de salud terminal de los participantes.
	 * @return Cadena de texto correspondiente a la entidad victoriosa o el indicador estándar de empate.
	 */
	public static String obtenerGanador(ArrayList<Planeta> equipos) {
		//EN caso de no haber ganador como no modificaremos el string lo inicializamos con la palabra "Nadie"
		String ganador = "Nadie";
		
		// Buscamos cual es el equipo ganador
		for (Planeta p : equipos) {
			if (p.getVidas() > 0) {
				ganador = p.getNombre().replace('.', ' ');
				break; 
			}
		}

		// Añadimos el ganador al archivo.txt
		try {
			FileWriter escritor = new FileWriter("ganadores_coldwar.txt", true); 
			// EN caso de que no ganase nadie (Empate) mostramos que hubo un empate
			if (ganador.equals("Nadie")) {
				escritor.write("EMPATE (Ningún superviviente)\n");
			} else {
				escritor.write(ganador + "\n"); 
			}
			
			escritor.close();
		} catch (IOException ex) {
			System.out.println("❌ Error interno: No se pudo guardar el historial de ganadores.");
		}

		return ganador;
	}

